# 宿主机访问端口
# 安全提示：当前端口映射适合本机 / 局域网调试，不建议直接映射公网。
# v1.1.2 已提供管理端登录；OpenAPI Token 与安全部署建议仍在后续补充。
APP_PORT=8080

# 镜像标签，image 模式可直接拉取该 tag；生产推荐固定为精确版本
# 默认 compose 使用 GHCR：ghcr.io/wangjiqing/xingyu-music-vault
# 如需 Docker Hub，将 compose image 改为：wangjiqing/xingyu-music-vault:${IMAGE_TAG:-v1.1.2}
IMAGE_TAG=v1.1.2

# Docker 构建源；海外或私有网络可改回官方源
NPM_REGISTRY=https://registry.npmmirror.com
MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public

# 时区
TZ=Asia/Shanghai

# 持久化数据目录，SQLite 数据库会写入此目录
DATA_DIR=./data

# 可选配置目录
CONFIG_DIR=./config

# 可选日志目录，当前主要日志仍输出到 docker logs
LOGS_DIR=./logs

# 音乐目录，默认按只读方式挂载到容器 /music
MUSIC_DIR=./music

# 歌词目录，默认按只读方式挂载到容器 /lyrics
LYRICS_DIR=./lyrics

# 封面目录，默认读写挂载到容器 /artwork，便于后台导入封面
ARTWORK_DIR=./artwork

# 历史管理 API Token 配置；v1.1.2 管理端登录不再依赖它
MUSIC_VAULT_API_TOKEN=change-me

# 管理端 Session Cookie 配置；本地 / 局域网 HTTP 部署默认 secure=false
XINGYU_ADMIN_COOKIE_SECURE=false
XINGYU_ADMIN_COOKIE_SAME_SITE=Lax
XINGYU_ADMIN_SESSION_TTL_MINUTES=1440

# OpenAPI 独立认证，默认关闭；开启后请修改 token
XINGYU_OPENAPI_AUTH_ENABLED=false
XINGYU_OPENAPI_AUTH_TOKEN=change-me-openapi

# OpenAPI 简单 IP 限流
XINGYU_OPENAPI_RATE_LIMIT_ENABLED=false
XINGYU_OPENAPI_RATE_LIMIT_REQUESTS_PER_MINUTE=120

# OpenAPI 访问日志
XINGYU_OPENAPI_ACCESS_LOG_ENABLED=true
