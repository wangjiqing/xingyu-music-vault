# 宿主机访问端口
APP_PORT=8080

# 镜像标签，image 模式可直接拉取该 tag；生产推荐固定为精确版本
IMAGE_TAG=v0.9.8

# Docker 构建源；海外或私有网络可改回官方源
NPM_REGISTRY=https://registry.npmmirror.com
MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public

# 时区
TZ=Asia/Shanghai

# 持久化数据目录，SQLite 数据库会写入此目录
DATA_DIR=./data

# 可选配置目录
CONFIG_DIR=./config

# 可选日志目录，当前主要日志仍输出到 docker logs
LOGS_DIR=./logs

# 音乐目录，默认按只读方式挂载到容器 /music
MUSIC_DIR=./music

# 歌词目录，默认按只读方式挂载到容器 /lyrics
LYRICS_DIR=./lyrics

# 封面目录，默认读写挂载到容器 /artwork，便于后台导入封面
ARTWORK_DIR=./artwork

# 后台管理 API Token，请部署时修改
MUSIC_VAULT_API_TOKEN=change-me

# OpenAPI 独立认证，默认关闭；开启后请修改 token
XINGYU_OPENAPI_AUTH_ENABLED=false
XINGYU_OPENAPI_AUTH_TOKEN=change-me-openapi

# OpenAPI 简单 IP 限流
XINGYU_OPENAPI_RATE_LIMIT_ENABLED=false
XINGYU_OPENAPI_RATE_LIMIT_REQUESTS_PER_MINUTE=120

# OpenAPI 访问日志
XINGYU_OPENAPI_ACCESS_LOG_ENABLED=true
