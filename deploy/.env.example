# 宿主机访问端口
# 安全提示：当前端口映射适合本机 / 局域网调试，不建议直接映射公网。
# 远端访问推荐通过 HTTPS 反向代理，不建议直接暴露后端端口。
APP_PORT=18081

# 镜像标签，image 模式可直接拉取该 tag；生产推荐固定为精确版本
# 默认 compose 使用 GHCR：ghcr.io/wangjiqing/xingyu-music-vault
# 如需 Docker Hub，将 compose image 改为：wangjiqing/xingyu-music-vault:${IMAGE_TAG:-v1.3.1}
IMAGE_TAG=v1.3.1

# Docker 构建源；海外或私有网络可改回官方源
NPM_REGISTRY=https://registry.npmmirror.com
MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public

# 时区
TZ=Asia/Shanghai

# 持久化数据目录，SQLite 数据库会写入此目录
DATA_DIR=./data

# 可选配置目录
CONFIG_DIR=./config

# 可选日志目录，当前主要日志仍输出到 docker logs
LOGS_DIR=./logs

# 音乐目录，默认按只读方式挂载到容器 /music
MUSIC_DIR=./music

# 歌词目录，默认读写挂载到容器 /lyrics；正式对齐 LRC / SWLRC 会发布到其受控 alignment 子目录
LYRICS_DIR=./lyrics

# 正式对齐 LRC / SWLRC 发布根目录；必须等于容器内某个 MUSIC_VAULT_LYRIC_DIRS 根目录
MUSIC_VAULT_ALIGNMENT_LYRICS_ROOT=/lyrics
MUSIC_VAULT_ALIGNMENT_LYRICS_SUBDIR=alignment

# 歌词对齐任务共享目录；音库挂载为 /alignment-jobs，Worker 挂载为 /jobs
ALIGNMENT_JOBS_DIR=./alignment-jobs

# 歌词对齐 Worker 模型缓存目录，挂载到 Worker /models；也可指向本机 ~/.cache/huggingface
ALIGNMENT_MODELS_DIR=./alignment-models

# 歌词对齐 / 草稿提取 Worker 镜像；v0.4.0 支持 LYRICS_ALIGNMENT 与 LYRIC_DRAFT_EXTRACTION
ALIGNMENT_WORKER_IMAGE=wangjiqing/xingyu-lyrics-aligner:0.4.0

# 音库扫描 Worker 任务状态的间隔秒数
ALIGNMENT_STATUS_SYNC_INTERVAL_SECONDS=5

# 歌词草稿提取默认 ASR 模型与音库可保存的最大草稿文本字节数
ALIGNMENT_DRAFT_DEFAULT_ASR_MODEL=medium
ALIGNMENT_DRAFT_DEFAULT_SKIP_SEPARATION=false
ALIGNMENT_DRAFT_DEFAULT_VAD_FILTER=true
ALIGNMENT_DRAFT_MAX_TEXT_BYTES=131072

# 封面目录，默认读写挂载到容器 /artwork，便于后台导入封面
ARTWORK_DIR=./artwork

# 容器内封面扫描目录，必须与 application.yml 的 app.artwork.scan-dir 保持一致
APP_ARTWORK_SCAN_DIR=/artwork

# 历史管理 API Token 配置；v1.1.2 管理端登录不再依赖它
MUSIC_VAULT_API_TOKEN=change-me

# 管理端 Session Cookie 配置；本地 / 局域网 HTTP 部署默认 secure=false
XINGYU_ADMIN_COOKIE_SECURE=false
XINGYU_ADMIN_COOKIE_SAME_SITE=Lax
XINGYU_ADMIN_SESSION_TTL_MINUTES=1440
# 测试兼容旧 Bearer Token 分支，生产环境必须保持 false
XINGYU_ADMIN_TEST_LEGACY_TOKEN_ENABLED=false

# OpenAPI AK/SK 凭证加密 master key。生产环境必须改成高强度随机值。
XINGYU_OPENAPI_CREDENTIAL_MASTER_KEY=change-me-openapi-master-key
XINGYU_OPENAPI_HMAC_TIMESTAMP_WINDOW_SECONDS=300
XINGYU_OPENAPI_HMAC_NONCE_TTL_SECONDS=600
XINGYU_OPENAPI_HMAC_MAX_BODY_BYTES=1048576

# v1.1.3 已废弃旧 OpenAPI 静态 Token；以下旧配置不再参与 OpenAPI 认证。
XINGYU_OPENAPI_AUTH_ENABLED=false
XINGYU_OPENAPI_AUTH_TOKEN=

# OpenAPI 简单 IP 限流
XINGYU_OPENAPI_RATE_LIMIT_ENABLED=false
XINGYU_OPENAPI_RATE_LIMIT_REQUESTS_PER_MINUTE=120

# OpenAPI 访问日志
XINGYU_OPENAPI_ACCESS_LOG_ENABLED=true
